widths><column index="1" value="21"/><column index="2" value="62"/><column index="3" value="44"/><column index="4" value="68"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="weton_arti_pair" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="24"/><column index="2" value="48"/><column index="3" value="60"/><column index="4" value="300"/><column index="5" value="300"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="wuku_awal" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="46"/><column index="2" value="66"/><column index="3" value="86"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="wuku_name" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="25"/><column index="2" value="86"/><column index="3" value="300"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">INSERT OR REPLACE INTO hari_lahir (hari, keterangan)
VALUES  (31,'Lahir pada tanggal 31 mencerminkan pribadi yang sangat mencintai keluarga, tradisi, dan komunitas, serta menjadi fondasi yang kuat dalam setiap pekerjaan atau tanggung jawab yang diemban. Anda menyukai hal-hal yang nyata dan praktis, namun tetap memiliki bakat artistik yang ingin diekspresikan secara konkret, termasuk kecintaan terhadap alam yang menyatukan keindahan, bentuk, dan fungsi. Anda adalah pengatur dan manajer alami dengan perhatian terhadap detail, mampu bekerja keras dan fokus, asalkan tetap menjaga keseimbangan diri agar tidak kelelahan.
Meski disiplin dan dapat diandalkan oleh rekan kerja, terkadang Anda merasa belum menemukan pekerjaan yang benar-benar sesuai atau menyalurkan bakat secara optimal. Tantangan utama adalah mengembangkan apa yang sedang dikerjakan menjadi karya yang bermakna, sambil menumbuhkan keyakinan dan kesediaan untuk mendedikasikan diri sepenuhnya. Keras kepala dan kecenderungan menolak ide-ide baru bisa menyebabkan frustrasi, sehingga penting untuk tetap terbuka terhadap pendekatan segar. Kunci kesuksesan Anda terletak pada kemampuan menjaga keteraturan, disiplin, dan memanfaatkan setiap kesempatan dengan tekad dan ketekunan yang konsisten.');</sql><current_tab id="0"/></tab_sql></sqlb_project>
